{
  "manifest_version": 3,
  "name": "PrintBill — Startup Tab",
  "version": "1.0.0",
  "description": "Efficient printing shop invoice management directly in your new tab.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "action": {
    "default_title": "PrintBill"
  },
  "permissions": ["storage"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
